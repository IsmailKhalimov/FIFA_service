# Скопируйте этот файл как .env и укажите реальные значения.
# Файл .env не должен попадать в git.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_service
DB_USER=postgres
DB_PASSWORD=

# Для облачного PostgreSQL с SSL часто нужно: require или verify-full
# DB_SSLMODE=require

# Одноразовая загрузка фото в S3 (Sports.ru -> Wikipedia)
# S3_BUCKET=my-bucket
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Опционально: свой домен / CloudFront вместо стандартного URL бакета
# S3_PUBLIC_BASE_URL=https://d123abc.cloudfront.net
# MinIO и совместимые S3:
# S3_ENDPOINT_URL=http://127.0.0.1:9000
